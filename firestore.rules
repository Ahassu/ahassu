rules_version = '2';

// No login/auth in this app (single personal user, per design choice).
// Access is scoped to only the collections Ahassu uses, not project-wide.
service cloud.firestore {
  match /databases/{database}/documents {
    match /learningPaths/{docId} {
      allow read, write: if true;
    }
    match /notes/{docId} {
      allow read, write: if true;
    }
    match /studySessions/{docId} {
      allow read, write: if true;
    }
    match /quizQuestions/{docId} {
      allow read, write: if true;
    }
    match /goal/{docId} {
      allow read, write: if true;
    }
    match /roadmaps/{docId} {
      allow read, write: if true;
    }
  }
}
